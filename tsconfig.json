{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": ".",
    "noEmit": false
  },
  "include": ["index.ts", "lib/**/*.ts", "routes/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
